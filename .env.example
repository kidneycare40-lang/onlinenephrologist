# Database
DATABASE_URL="postgresql://user:password@localhost:5432/kidneycarecentre"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here"

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# WhatsApp Business API
WHATSAPP_API_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="noreply@kidneycarecentre.in"

# Site
NEXT_PUBLIC_SITE_URL="https://www.kidneycarecentre.in"
NEXT_PUBLIC_SITE_NAME="Kidney Care Centre"
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_WHATSAPP_NUMBER="919818235613"
NEXT_PUBLIC_EMERGENCY_NUMBER="919818235688"

# Google Sheets (Create a Google Sheet → Extensions → Apps Script → Deploy as Web App)
GOOGLE_SHEETS_WEB_APP_URL=""

# Setup key for initial credential bootstrap (/api/auth/init)
SETUP_KEY=emr-setup-2026-kcc-admin

# JWT Secret for authentication tokens (REQUIRED - generate a strong random string)
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-chars
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-service-role-key
